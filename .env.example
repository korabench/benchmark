# Vercel AI Gateway key. Required for any model addressed through the gateway
# (named entries in models.json without `provider: openai-compatible`).
AI_GATEWAY_API_KEY=

# OpenAI-compatible providers (optional). Set when you want to use a slug like
# `vllm/<model-id>` as the target, judge, or user model.
# VLLM_BASE_URL=http://localhost:8000/v1
# VLLM_API_KEY=EMPTY

# OpenAI direct (optional). Set to address OpenAI models via the
# `openai/<model-id>` slug — bypasses the gateway and hits api.openai.com.
# OPENAI_BASE_URL defaults to https://api.openai.com/v1; override to point
# at an OpenAI-compatible proxy.
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
